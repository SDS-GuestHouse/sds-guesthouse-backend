<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sds_guesthouse.model.dao.AdminMapper">

    <select id="findByUserId" parameterType="string" resultType="com.sds_guesthouse.model.entity.Admin">
        SELECT admin_id, user_id, password, name, phone, created_at, updated_at
        FROM admins
        WHERE user_id = #{userId}
    </select>

</mapper>