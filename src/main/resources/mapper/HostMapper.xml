<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sds_guesthouse.model.mapper.HostMapper">

    <select id="existsByUserId" parameterType="string" resultType="boolean">
        SELECT COUNT(*)
        FROM host
        WHERE user_id = #{userId}
    </select>

    <insert id="insertHost" parameterType="com.sds_guesthouse.model.entity.Host">
        INSERT INTO host (
            user_id, 
            name, 
            password, 
            phone, 
            created_at, 
            updated_at
        ) VALUES (
            #{userId}, 
            #{name}, 
            #{password}, 
            #{phone}, 
            NOW(), 
            NOW()
        )
    </insert>

</mapper>